# --- Supabase ---
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- CRM integration ---
# "rest" or "mcp". Leave unset to run in no-op/demo mode (logs only).
CRM_MODE=

# Used when CRM_MODE=rest
CRM_API_URL=https://your-crm.example.com/api/records
CRM_API_KEY=your-crm-api-key

# Used when CRM_MODE=mcp
# Point this at whatever bridges your MCP tool call to HTTP (e.g. an
# internal service, or Anthropic's MCP connector gateway).
CRM_MCP_ENDPOINT=https://your-mcp-bridge.example.com/call
